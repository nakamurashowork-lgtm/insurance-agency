APP_ENV=production
APP_URL=https://example.xsrv.jp/insurance-agency
APP_PUBLIC_URL=https://example.xsrv.jp/insurance-agency

COMMON_DB_HOST=127.0.0.1
COMMON_DB_PORT=3306
COMMON_DB_NAME=insurance_common
COMMON_DB_USER=insurance_user
COMMON_DB_PASSWORD=change-me

TENANT_DB_HOST=127.0.0.1
TENANT_DB_PORT=3306
TENANT_DB_USER=insurance_user
TENANT_DB_PASSWORD=change-me

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://example.xsrv.jp/insurance-agency/?route=auth/google/callback

SESSION_COOKIE_NAME=INS_AGENCY_SESSID
SESSION_COOKIE_SECURE=true
