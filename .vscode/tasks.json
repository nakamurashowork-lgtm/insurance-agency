{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "batchDate",
      "type": "promptString",
      "description": "実行対象日（YYYY-MM-DD）",
      "default": ""
    },
    {
      "id": "batchType",
      "type": "pickString",
      "description": "通知種別",
      "options": ["renewal", "accident", "all"],
      "default": "renewal"
    },
    {
      "id": "batchTenant",
      "type": "promptString",
      "description": "テナントコード（空欄で全テナント）",
      "default": ""
    },
    {
      "id": "batchTypeNoTenant",
      "type": "pickString",
      "description": "通知種別",
      "options": ["renewal", "accident", "all"],
      "default": "renewal"
    },
    {
      "id": "batchTypeTodayTenant",
      "type": "pickString",
      "description": "通知種別",
      "options": ["renewal", "accident", "all"],
      "default": "renewal"
    },
    {
      "id": "batchTenantToday",
      "type": "promptString",
      "description": "テナントコード（空欄で全テナント）",
      "default": ""
    }
  ],
  "tasks": [
    {
      "label": "通知バッチ：日付指定",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "tools\\batch\\run_renewal_notification.ps1",
        "-date", "${input:batchDate}",
        "-type", "${input:batchType}",
        "-tenant", "${input:batchTenant}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "通知バッチ：今日・全テナント",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "tools\\batch\\run_renewal_notification.ps1",
        "-type", "${input:batchTypeNoTenant}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "通知バッチ：今日・テナント指定",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "tools\\batch\\run_renewal_notification.ps1",
        "-type", "${input:batchTypeTodayTenant}",
        "-tenant", "${input:batchTenantToday}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
